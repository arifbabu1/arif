  <script>
    // ====== Config you will edit ======
    const CV_URL = "/static/files/Md_Arif_Babu_CV.pdf"; // <-- change to your CV file path

    // Django contact endpoint:
    // In Django templates, CSRF token should be included.
    // If you use Django's template engine, add {% csrf_token %} inside the form.
    // For AJAX, the code below reads CSRF from cookie if present.
    const CONTACT_URL = "/contact/"; // must match Django urls.py
    // ==================================

    // CV download
    const cvBtn = document.getElementById("cvBtn");
    cvBtn.href = CV_URL;

    // Year
    document.getElementById("year").textContent = new Date().getFullYear();

    // Language toggle
    const langToggle = document.getElementById("langToggle");
    function setLang(mode){
      document.documentElement.classList.toggle("bn", mode === "bn");
      langToggle.textContent = mode === "bn" ? "English" : "বাংলা";
    }
    // default English
    setLang("en");
    langToggle.addEventListener("click", () => {
      const isBn = document.documentElement.classList.contains("bn");
      setLang(isBn ? "en" : "bn");
    });

    // Section switching (no scroll: only show selected)
    const buttons = document.querySelectorAll(".nav-btn");
    const sections = document.querySelectorAll(".section");

    function setActive(targetId){
      sections.forEach(sec => sec.classList.toggle("active", sec.id === targetId));
      buttons.forEach(btn => btn.classList.toggle("active", btn.dataset.target === targetId));
    }

    buttons.forEach(btn => {
      btn.addEventListener("click", () => setActive(btn.dataset.target));
    });

    // Buttons that navigate without scrolling
    document.querySelectorAll("[data-nav]").forEach(el => {
      el.addEventListener("click", () => setActive(el.getAttribute("data-nav")));
    });
    document.querySelectorAll("[data-scrollto]").forEach(el => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        setActive(el.getAttribute("data-scrollto"));
      });
    });

    // 3D Tilt
    document.querySelectorAll("[data-tilt]").forEach(card => {
      const max = 10; // degrees
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;  // 0..1
        const py = (e.clientY - r.top) / r.height;  // 0..1

        const tiltX = (0.5 - py) * max;
        const tiltY = (px - 0.5) * max;

        card.style.setProperty("--mx", (px * 100).toFixed(2) + "%");
        card.style.setProperty("--my", (py * 100).toFixed(2) + "%");

        card.style.transform =
          `rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateZ(10px)`;
      });

      card.addEventListener("mouseleave", () => {
        card.style.transform = `rotateX(0deg) rotateY(0deg) translateZ(0px)`;
      });
    });

    // Modal projects
    const projectModal = document.getElementById("projectModal");
    const modalClose = document.getElementById("modalClose");
    const modalTitle = document.getElementById("modalTitle");
    const modalBadge = document.getElementById("modalBadge");
    const modalBody = document.getElementById("modalBody");

    function openModal(payload){
      modalTitle.textContent = payload.title || "Project";
      modalBadge.textContent = payload.badge ? `• ${payload.badge}` : "";
      modalBody.textContent = payload.body || "";
      projectModal.classList.add("open");
      projectModal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }
    function closeModal(){
      projectModal.classList.remove("open");
      projectModal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    document.querySelectorAll(".project-card").forEach(card => {
      const getPayload = () => {
        try { return JSON.parse(card.getAttribute("data-project")); }
        catch { return {}; }
      };

      card.addEventListener("click", () => openModal(getPayload()));
      card.addEventListener("keydown", (e) => {
        if(e.key === "Enter" || e.key === " "){
          e.preventDefault();
          openModal(getPayload());
        }
      });
    });

    modalClose.addEventListener("click", closeModal);
    projectModal.addEventListener("click", (e) => {
      if(e.target === projectModal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if(e.key === "Escape" && projectModal.classList.contains("open")) closeModal();
    });

    // Django contact AJAX (optional but nice)
    function getCookie(name){
      const match = document.cookie.match(new RegExp("(^| )" + name + "=([^;]+)"));
      return match ? decodeURIComponent(match[2]) : null;
    }

    const contactForm = document.getElementById("contactForm");
    const formStatus = document.getElementById("formStatus");

    contactForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      formStatus.textContent = "Sending...";

      const formData = new FormData(contactForm);

      // If you use Django templates, add {% csrf_token %} to the form
      // then CSRF token will be present as cookie for typical setups.
      const csrftoken = getCookie("csrftoken");

      try{
        const res = await fetch(CONTACT_URL, {
          method: "POST",
          headers: {
            "X-Requested-With": "XMLHttpRequest",
            ...(csrftoken ? {"X-CSRFToken": csrftoken} : {})
          },
          body: formData
        });

        if(!res.ok){
          throw new Error("Request failed");
        }

        const data = await res.json().catch(() => ({}));
        formStatus.textContent = data.message || "Sent! Thanks for contacting.";
        contactForm.reset();
      }catch(err){
        formStatus.textContent = "Something went wrong. Please try again.";
      }
    });
  </script>
