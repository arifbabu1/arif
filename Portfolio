          <div style="margin-top:6px; color:var(--muted); font-weight:800;" id="modalBadge"></div>
        </div>
        <button class="close" type="button" id="modalClose">Close</button>
      </div>
      <div class="modal-body" id="modalBody"></div>
    </div>
